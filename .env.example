# CDN Monitoring System Configuration

# Server Configuration
INGEST_TOKEN=change-me-to-a-random-string
JWT_SECRET=change-me-to-a-random-string
SESSION_HOURS=24
RETENTION_DAYS=30
AUTO_BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=cdn-monitor-2026!

# Agent Configuration
CDN_NAME=cdn1
TARGET_PORT=443
INTERVAL_SECONDS=10
SERVER_ENDPOINT=http://server:18443/api/ingest
AGENT_HOST=

# Notes:
# - INGEST_TOKEN: Used by agents to authenticate metric submissions
# - JWT_SECRET: Used for signing session tokens (must be changed in production)
# - SESSION_HOURS: How long user sessions remain valid
# - RETENTION_DAYS: How many days of metrics to keep (older metrics are auto-deleted)
# - CDN_NAME: Identifier for this monitoring agent (can have multiple agents with different names)
# - TARGET_PORT: The port to monitor for TCP connections
# - INTERVAL_SECONDS: How often the agent collects and sends metrics
# - SERVER_ENDPOINT: Where the agent sends metrics (http://server:18443/api/ingest for docker)
# - AGENT_HOST: Hostname for metrics (auto-detected if empty)
